# Nautilus Full Showcase — Optional Credentials
#
# Copy this file to .env and fill in the values you have.
# The showcase works without any of these — they unlock additional features.
#
#   cp .env.example .env
#
# Then rebuild:
#   docker compose up --build -d

# ── Anthropic API (enables LLM intent analysis) ────────────────────────
# Switches intent analyzer from pattern-matching to Claude-backed analysis
# with automatic fallback to pattern matching on timeout/error.
# Get a key at https://console.anthropic.com/
ANTHROPIC_API_KEY=

# ── ServiceNow (enables incident table adapter) ────────────────────────
# Requires a ServiceNow instance. The adapter queries the Table API.
# SNOW_INSTANCE is just the subdomain (e.g. "dev12345" for dev12345.service-now.com)
SNOW_INSTANCE=
SNOW_USER=
SNOW_PASS=
